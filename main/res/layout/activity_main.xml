<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/rootLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="WATT METER"
                    android:textColor="#3D3D3D"
                    android:textSize="11sp"
                    android:letterSpacing="0.3"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="History"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingEnd="12dp"/>
                <TextView
                    android:id="@+id/tvChargingIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="22sp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A1A1A"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvWattage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0W"
                android:textColor="#FFFFFF"
                android:textSize="88sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="-0.03"
                android:layout_marginTop="32dp"
                android:layout_gravity="center_horizontal"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp">

                <View
                    android:id="@+id/viewTypeDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#6B6B6B"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvChargingType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not Charging"
                    android:textColor="#6B6B6B"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvBatteryPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#FFFFFF"
                android:textSize="42sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="40dp"/>

            <ProgressBar
                android:id="@+id/progressBattery"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:max="100"
                android:progress="0"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvTimeToFull"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not charging"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A1A1A"
                android:layout_marginTop="32dp"/>

            <!-- Card 1: Voltage + Current -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VOLTAGE"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvVoltage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00 V"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#1A1A1A"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CURRENT"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvCurrent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 mA"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Temp + Health -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvTempLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TEMP °C"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvTemperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0°C"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"
                            android:clickable="true"/>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#1A1A1A"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HEALTH"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvHealth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Source + Peak -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOURCE"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvSource"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#1A1A1A"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PEAK"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvPeak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0W"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Avg + Efficiency -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AVG"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvAverage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0W"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#1A1A1A"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EFFICIENCY"
                            android:textColor="#3D3D3D"
                            android:textSize="10sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvEfficiency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Footer -->
            <TextView
                android:id="@+id/tvFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updates every 1.5 seconds"
                android:textColor="#2A2A2A"
                android:textSize="11sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>